JWT_SECRET=change-me-in-development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional: set to true only if you use cookies across origins
CORS_ALLOW_CREDENTIALS=false
# Optional: JWT lifetime in seconds (defaults to 86400 = 24h)
JWT_EXPIRES_IN_SECONDS=86400

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
# IMPORTANT: Change this to a secure random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Token Expiration
JWT_EXPIRES_IN=7d

# Database
# For SQLite, this is the path to the database file
DATABASE_PATH=./fish_app.db

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=10

# Gemini API Key - MUST be server-side only (no VITE_ prefix)
# Used for AI features like spreadsheet parsing
# NEVER expose to client - all Gemini calls must go through server endpoints
GEMINI_API_KEY=AIza...
