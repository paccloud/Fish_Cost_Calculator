# Required: JWT signing secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-development

# Required: comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: set to true only if you use cookies across origins
CORS_ALLOW_CREDENTIALS=false

# Optional: JWT lifetime in seconds (defaults to 86400 = 24h)
JWT_EXPIRES_IN_SECONDS=86400

# Optional: override listening port (defaults to 3000)
PORT=3000
