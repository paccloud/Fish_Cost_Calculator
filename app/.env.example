# Environment Variables Template
# Copy this file to .env.development for local development

# API Configuration
# For local development, use: http://localhost:3000
# For production, leave empty (same-origin)
VITE_API_URL=http://localhost:3000

# Database connection string (backend — set in Vercel dashboard for prod)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT secret for auth (backend — set in Vercel dashboard for prod)
JWT_SECRET=your-secret-key
